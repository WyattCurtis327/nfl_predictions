{
  "table": "nfl.teams.nfelo_ratings",
  "comment": "Latest nfelo team power ratings snapshot ingested from the public nfelo GitHub repo.",
  "columns": [
    {"name": "team", "type": "string", "nullable": true, "comment": "nflverse team abbreviation."},
    {"name": "season", "type": "bigint", "nullable": true, "comment": "nfelo rating season."},
    {"name": "week", "type": "bigint", "nullable": true, "comment": "nfelo rating week."},
    {"name": "nfelo", "type": "double", "nullable": true, "comment": "Composite nfelo power rating."},
    {"name": "nfelo_base", "type": "double", "nullable": true, "comment": "Base Elo component before adjustments."},
    {"name": "qb_adj", "type": "double", "nullable": true, "comment": "Quarterback adjustment applied to the rating."},
    {"name": "pts_vs_avg", "type": "double", "nullable": true, "comment": "Expected scoring relative to league average."},
    {"name": "ingested_at", "type": "string", "nullable": true, "comment": "UTC ingest timestamp."},
    {"name": "_source_file", "type": "string", "nullable": true, "comment": "Upstream source identifier."}
  ]
}