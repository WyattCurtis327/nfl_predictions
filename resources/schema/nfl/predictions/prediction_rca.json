{
  "table": "nfl.predictions.prediction_rca",
  "comment": "Deterministic root-cause analysis for missed spread and total picks.",
  "columns": [
    {"name": "rca_id", "type": "string", "nullable": true, "comment": "UUID for one RCA row."},
    {"name": "rca_run_id", "type": "string", "nullable": true, "comment": "UUID grouping one RCA notebook execution."},
    {"name": "grading_run_id", "type": "string", "nullable": true, "comment": "Source grading_run_id from prediction_grades."},
    {"name": "grade_id", "type": "string", "nullable": true, "comment": "Graded game row id."},
    {"name": "prediction_id", "type": "string", "nullable": true, "comment": "Source prediction row id."},
    {"name": "game_id", "type": "string", "nullable": true, "comment": "nflverse game identifier."},
    {"name": "season", "type": "bigint", "nullable": true, "comment": "Graded game season."},
    {"name": "week", "type": "bigint", "nullable": true, "comment": "Graded game week."},
    {"name": "miss_types", "type": "string", "nullable": true, "comment": "Comma-separated miss types: spread, total."},
    {"name": "primary_cause", "type": "string", "nullable": true, "comment": "Top-ranked deterministic cause label."},
    {"name": "cause_summary", "type": "string", "nullable": true, "comment": "JSON array of ranked cause objects with label, detail, weight."},
    {"name": "analyzed_at", "type": "string", "nullable": true, "comment": "UTC timestamp when RCA ran."}
  ]
}