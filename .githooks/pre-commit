#!/usr/bin/env bash
# Optional pre-commit hook. Install once from repo root:
#   git config core.hooksPath .githooks
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"
if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  echo "pre-commit: python not found" >&2
  exit 1
fi
"$PY" scripts/check_public_ready.py
