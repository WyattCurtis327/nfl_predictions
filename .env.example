# Copy to .env and fill in your values. Never commit .env.
#   copy .env.example .env          (Windows)
#   cp .env.example .env            (macOS / Linux)
#
# After editing, run:  python scripts/sync_bundle_env.py
# That writes host/profile into gitignored .env / .databricks/ only.

# Required: Databricks CLI profile from ~/.databrickscfg
# Create with:  databricks auth login --profile <name>
DATABRICKS_CONFIG_PROFILE=

# Alias read by scripts/deploy_bundle.py (falls back to DATABRICKS_CONFIG_PROFILE)
databricks_profile=

# Optional: workspace URL (usually filled by sync_bundle_env.py from your profile)
# DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com

# Serverless Databricks Connect (set by sync_bundle_env.py if missing)
DATABRICKS_SERVERLESS_COMPUTE_ID=auto

# Do NOT set DATABRICKS_CLUSTER_ID here or in user env when using VS Code
# serverless Connect. Remove any stale DATABRICKS_CLUSTER_ID from System
# Properties → Environment Variables → User.

# Required for job failure emails and deploy_bundle.py
DATABRICKS_EMAIL_ACCOUNT=

# Required for Genie spaces, metric-view deploy, and Streamlit apps.
# SQL Warehouses → your warehouse → copy ID from the URL.
DATABRICKS_WAREHOUSE_ID=

# Optional: The Odds API key for live weekly odds (not needed for nflverse bootstrap)
# https://the-odds-api.com — also store in a Databricks secret scope for cloud jobs:
#   python scripts/set_odds_api_secret.py --profile <your-profile>
ODDS_API_KEY=

# Optional after first Genie deploy (usually filled from bundle state by sync):
# genie_pick_metrics_space_id=
# genie_pick_miss_rca_space_id=
