# Copy to .env and fill in your values. Never commit .env.

# Databricks CLI profile from ~/.databrickscfg (used by bundle validate/deploy)
DATABRICKS_CONFIG_PROFILE=

# Do NOT set DATABRICKS_CLUSTER_ID here or in Windows user env when using VS Code
# serverless Connect (DATABRICKS_SERVERLESS_COMPUTE_ID=auto). Remove any stale
# DATABRICKS_CLUSTER_ID from System Properties → Environment Variables → User.

# Alias read by scripts/deploy_bundle.py (falls back to DATABRICKS_CONFIG_PROFILE)
databricks_profile=

# Job failure notification email (used by scripts/deploy_bundle.py)
DATABRICKS_EMAIL_ACCOUNT=

# Optional: The Odds API key for live weekly odds (not needed for nflverse bootstrap)
ODDS_API_KEY=

# After editing .env, run: python scripts/sync_bundle_env.pyS